    {
      "id": "risk-tx",
      "type": "text",
      "x": 56,
      "y": 552,
      "width": 888,
      "height": 64,
      "text": "⚠️ OPTIMISM IS DANGEROUS\nStale data · Wasted bandwidth · Pre-auth leaks · State mutation · Memory bloat\nMitigate: read-only prefetch · post-auth gate · delta sync · Cache-Control: no-store on logout",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
