      "link": null,
      "locked": false
    },
    {
      "id": "concept-text",
      "type": "text",
      "x": 935,
      "y": 235,
      "width": 290,
      "height": 210,
      "text": "1. Servers sit on a circular ring\n\n2. Keys hash to positions on ring\n\n3. Each key goes to the NEXT\n   server clockwise\n\n4. Adding a server only affects\n   keys between it and the\n   next server\n\n5. Result: Only 1/N of data moves\n   (not everything!)",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#e0e0e0",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "seed": 61,
      "version": 1,
      "versionNonce": 61,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false
    },
