    },
    {
      "id": "comparison-text",
      "type": "text",
      "x": 935,
      "y": 530,
      "width": 290,
      "height": 140,
      "text": "Modulo Hashing:\n  key % 4 → key % 5\n  ❌ ~80% of keys move!\n\nConsistent Hashing:\n  Add server E at 180°\n  ✅ Only 20% of keys move!\n\n🏆 4x LESS data migration!",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#e0e0e0",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
