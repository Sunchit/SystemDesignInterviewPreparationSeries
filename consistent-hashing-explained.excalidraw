    {
      "id": "concept-title",
      "type": "text",
      "x": 935,
      "y": 195,
      "width": 280,
      "height": 30,
      "text": "🎯 THE KEY CONCEPT",
      "fontSize": 24,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#4dabf7",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "seed": 60,
      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
