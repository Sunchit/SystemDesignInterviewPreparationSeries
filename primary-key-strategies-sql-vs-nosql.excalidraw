    {
      "id": "t-table",
      "type": "text",
      "x": 64,
      "y": 600,
      "width": 992,
      "height": 144,
      "text": "Quick compare\nSQL: int PK · gaps OK · server gen · sequential locality · smaller storage\nNoSQL: UUID/ObjectId · no gaps concept · distributed gen · opaque / unguessable · larger keys\n\nGaps matter for: invoices, regulated sequences, human-readable order #\nGaps OK for: internal surrogate keys, opaque to users",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#cbd5e1",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "seed": 4013,
      "version": 1,
      "versionNonce": 40013,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Quick compare\nSQL: int PK · gaps OK · server gen · sequential locality · smaller storage\nNoSQL: UUID/ObjectId · no gaps concept · distributed gen · opaque / unguessable · larger keys\n\nGaps matter for: invoices, regulated sequences, human-readable order #\nGaps OK for: internal surrogate keys, opaque to users",
      "angle": 0,
      "groupIds": []
    },
