    {
      "id": "t-sql-h",
      "type": "text",
      "x": 64,
      "y": 160,
      "width": 468,
      "height": 32,
      "text": "🗄️ SQL — Sequential PKs",
      "fontSize": 20,
      "fontFamily": 1,
      "strokeColor": "#6ee7b7",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "seed": 4005,
      "version": 1,
      "versionNonce": 40005,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "🗄️ SQL — Sequential PKs",
      "angle": 0,
      "groupIds": []
    },
    {
      "id": "t-sql-body",
      "type": "text",
      "x": 64,
      "y": 200,
      "width": 468,
      "height": 200,
      "text": "• AUTO_INCREMENT / SERIAL\n• Server-side, centralized counter\n• Gaps: DELETE, ROLLBACK, replication\n• Implicit order (often newer = larger)\n• Great for B-tree insert locality\n• Predictable — hide if public-facing",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#d1fae5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "seed": 4006,
      "version": 1,
      "versionNonce": 40006,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• AUTO_INCREMENT / SERIAL\n• Server-side, centralized counter\n• Gaps: DELETE, ROLLBACK, replication\n• Implicit order (often newer = larger)\n• Great for B-tree insert locality\n• Predictable — hide if public-facing",
      "angle": 0,
      "groupIds": []
    },
    {
      "id": "t-sql-gaps",
      "type": "text",
      "x": 64,
      "y": 420,
      "width": 468,
      "height": 132,
      "text": "Gaps example:\n  1 → 2 → 3  then DELETE 2  →  1, _, 3\n  ROLLBACK burns next id  →  …1, 3, 5",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#fde68a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "seed": 4007,
      "version": 1,
      "versionNonce": 40007,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Gaps example:\n  1 → 2 → 3  then DELETE 2  →  1, _, 3\n  ROLLBACK burns next id  →  …1, 3, 5",
      "angle": 0,
      "groupIds": []
    },
