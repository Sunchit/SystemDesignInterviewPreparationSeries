    {
      "id": "t-nosql-h",
      "type": "text",
      "x": 588,
      "y": 160,
      "width": 468,
      "height": 32,
      "text": "📦 NoSQL — Opaque IDs",
      "fontSize": 20,
      "fontFamily": 1,
      "strokeColor": "#c4b5fd",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "seed": 4009,
      "version": 1,
      "versionNonce": 40009,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "📦 NoSQL — Opaque IDs",
      "angle": 0,
      "groupIds": []
    },
    {
      "id": "t-nosql-body",
      "type": "text",
      "x": 588,
      "y": 200,
      "width": 468,
      "height": 200,
      "text": "• UUID / ObjectId / ULID\n• Often client-side or node-local\n• No shared “next id” counter\n• No gap semantics — IDs are tokens\n• Order: use created_at, not _id\n• Sharding: hash(id) spreads writes",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#e9d5ff",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "seed": 4010,
      "version": 1,
      "versionNonce": 40010,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• UUID / ObjectId / ULID\n• Often client-side or node-local\n• No shared “next id” counter\n• No gap semantics — IDs are tokens\n• Order: use created_at, not _id\n• Sharding: hash(id) spreads writes",
      "angle": 0,
      "groupIds": []
    },
    {
      "id": "t-nosql-oid",
      "type": "text",
      "x": 588,
      "y": 420,
      "width": 468,
      "height": 132,
      "text": "ObjectId (12 B):\n  [4B time][3B machine][2B pid][3B counter]\nUUID v4: random — no sequence",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#fde68a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "seed": 4011,
      "version": 1,
      "versionNonce": 40011,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ObjectId (12 B):\n  [4B time][3B machine][2B pid][3B counter]\nUUID v4: random — no sequence",
      "angle": 0,
      "groupIds": []
    },
