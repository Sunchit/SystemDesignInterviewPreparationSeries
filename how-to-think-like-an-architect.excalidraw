      "seed": 1100, "version": 1, "versionNonce": 1100,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "b10-num",
      "type": "text",
      "x": 62, "y": 1134,
      "width": 36, "height": 36,
      "text": "10",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#8a3a5a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1101, "version": 1, "versionNonce": 1101,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "10", "angle": 0, "groupIds": []
    },
    {
      "id": "b10-title",
      "type": "text",
      "x": 106, "y": 1136,
      "width": 830, "height": 22,
      "text": "Trade-offs are the job. There are no free choices.",
      "fontSize": 15, "fontFamily": 1,
      "strokeColor": "#f2cdcd", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1102, "version": 1, "versionNonce": 1102,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Trade-offs are the job. There are no free choices.", "angle": 0, "groupIds": []
    },
    {
      "id": "b10-body",
      "type": "text",
      "x": 106, "y": 1164,
      "width": 830, "height": 48,
      "text": "Every decision gives something and takes something away. Speed vs consistency. Simplicity vs flexibility. Cost vs resilience.\nA developer optimises within constraints. An architect negotiates the constraints — and documents every trade-off for the next person.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1103, "version": 1, "versionNonce": 1103,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Every decision gives something and takes something away. Speed vs consistency. Simplicity vs flexibility. Cost vs resilience.\nA developer optimises within constraints. An architect negotiates the constraints — and documents every trade-off for the next person.", "angle": 0, "groupIds": []
    },

