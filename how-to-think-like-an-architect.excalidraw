    },
    {
      "id": "b2-num",
      "type": "text",
      "x": 62, "y": 222,
      "width": 36, "height": 36,
      "text": "02",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#4a8a5a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1021, "version": 1, "versionNonce": 1021,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "02", "angle": 0, "groupIds": []
    },
    {
      "id": "b2-title",
      "type": "text",
      "x": 106, "y": 224,
      "width": 830, "height": 22,
      "text": "Every technical decision is a business decision.",
      "fontSize": 15, "fontFamily": 1,
      "strokeColor": "#a6e3a1", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1022, "version": 1, "versionNonce": 1022,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Every technical decision is a business decision.", "angle": 0, "groupIds": []
    },
    {
      "id": "b2-body",
      "type": "text",
      "x": 106, "y": 252,
      "width": 830, "height": 48,
      "text": "Choosing Kafka over RabbitMQ is a cost, hiring, and operational complexity choice — not just a tech choice.\nIf you can't explain your decision to a non-engineer, you don't fully understand it yet.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1023, "version": 1, "versionNonce": 1023,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Choosing Kafka over RabbitMQ is a cost, hiring, and operational complexity choice — not just a tech choice.\nIf you can't explain your decision to a non-engineer, you don't fully understand it yet.", "angle": 0, "groupIds": []
    },

    {
      "id": "b3-rect",
      "type": "rectangle",
      "x": 40, "y": 324,
      "width": 920, "height": 100,
      "strokeColor": "#8a3a3a", "backgroundColor": "#200e0e",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1030, "version": 1, "versionNonce": 1030,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "b3-num",
      "type": "text",
      "x": 62, "y": 336,
      "width": 36, "height": 36,
      "text": "03",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#8a3a3a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1031, "version": 1, "versionNonce": 1031,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "03", "angle": 0, "groupIds": []
    },
    {
      "id": "b3-title",
      "type": "text",
      "x": 106, "y": 338,
      "width": 830, "height": 22,
      "text": "Design for failure first, features second.",
      "fontSize": 15, "fontFamily": 1,
      "strokeColor": "#f38ba8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1032, "version": 1, "versionNonce": 1032,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Design for failure first, features second.", "angle": 0, "groupIds": []
    },
    {
      "id": "b3-body",
      "type": "text",
      "x": 106, "y": 366,
      "width": 830, "height": 48,
      "text": "Developers design for the happy path. Architects design for the crash, the timeout, the retry, the duplicate, the cascade.\nAsk yourself: \"What happens when this call fails?\" before \"How do I make this call?\"",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1033, "version": 1, "versionNonce": 1033,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Developers design for the happy path. Architects design for the crash, the timeout, the retry, the duplicate, the cascade.\nAsk yourself: \"What happens when this call fails?\" before \"How do I make this call?\"", "angle": 0, "groupIds": []
    },

    {
      "id": "b4-rect",
      "type": "rectangle",
      "x": 40, "y": 438,
      "width": 920, "height": 100,
      "strokeColor": "#7a5a9a", "backgroundColor": "#18102e",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1040, "version": 1, "versionNonce": 1040,
      "isDeleted": false, "boundElements": null, "updated": 1,
