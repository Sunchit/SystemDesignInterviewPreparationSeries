      "originalText": "08", "angle": 0, "groupIds": []
    },
    {
      "id": "b8-title",
      "type": "text",
      "x": 106, "y": 908,
      "width": 830, "height": 22,
      "text": "Observability is not optional — it is part of the design.",
      "fontSize": 15, "fontFamily": 1,
      "strokeColor": "#a6e3a1", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1082, "version": 1, "versionNonce": 1082,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Observability is not optional — it is part of the design.", "angle": 0, "groupIds": []
    },
    {
      "id": "b8-body",
      "type": "text",
      "x": 106, "y": 936,
      "width": 830, "height": 48,
      "text": "A system you cannot observe is a system you cannot operate. Metrics, traces, and logs are designed in from day one — not as an afterthought.\nIf you cannot answer \"is this system healthy right now?\" in under 60 seconds, the system is not finished.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1083, "version": 1, "versionNonce": 1083,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "A system you cannot observe is a system you cannot operate. Metrics, traces, and logs are designed in from day one — not as an afterthought.\nIf you cannot answer \"is this system healthy right now?\" in under 60 seconds, the system is not finished.", "angle": 0, "groupIds": []
    },

