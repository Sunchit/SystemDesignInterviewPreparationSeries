    {
      "id": "b4-num",
      "type": "text",
      "x": 62, "y": 450,
      "width": 36, "height": 36,
      "text": "04",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#7a5a9a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1041, "version": 1, "versionNonce": 1041,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "04", "angle": 0, "groupIds": []
    },
    {
      "id": "b4-title",
      "type": "text",
      "x": 106, "y": 452,
      "width": 830, "height": 22,
      "text": "More is not always better — more is usually the problem.",
      "fontSize": 15, "fontFamily": 1,
      "strokeColor": "#cba6f7", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1042, "version": 1, "versionNonce": 1042,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "More is not always better — more is usually the problem.", "angle": 0, "groupIds": []
    },
    {
      "id": "b4-body",
      "type": "text",
      "x": 106, "y": 480,
      "width": 830, "height": 48,
      "text": "More connections don't mean more throughput. More services don't mean more scalability. More features don't mean more value.\nAn architect's instinct: question every addition — what does this cost us in complexity, operations, and failure surface?",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1043, "version": 1, "versionNonce": 1043,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "More connections don't mean more throughput. More services don't mean more scalability. More features don't mean more value.\nAn architect's instinct: question every addition — what does this cost us in complexity, operations, and failure surface?", "angle": 0, "groupIds": []
    },

    {
      "id": "b5-rect",
      "type": "rectangle",
      "x": 40, "y": 552,
      "width": 920, "height": 100,
      "strokeColor": "#8a6a3a", "backgroundColor": "#201808",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1050, "version": 1, "versionNonce": 1050,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "b5-num",
      "type": "text",
      "x": 62, "y": 564,
      "width": 36, "height": 36,
      "text": "05",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#8a6a3a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1051, "version": 1, "versionNonce": 1051,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "05", "angle": 0, "groupIds": []
    },
    {
      "id": "b5-title",
      "type": "text",
      "x": 106, "y": 566,
      "width": 830, "height": 22,
      "text": "Consistency is a spectrum, not a switch.",
      "fontSize": 15, "fontFamily": 1,
      "strokeColor": "#f9e2af", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1052, "version": 1, "versionNonce": 1052,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Consistency is a spectrum, not a switch.", "angle": 0, "groupIds": []
    },
    {
      "id": "b5-body",
      "type": "text",
      "x": 106, "y": 594,
      "width": 830, "height": 48,
      "text": "Developers think in binary: consistent or not. Architects think in degrees — strong, eventual, causal, read-your-writes.\nEvery system lives somewhere on that spectrum. Knowing where yours sits, and why, is what separates architects from developers.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1053, "version": 1, "versionNonce": 1053,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Developers think in binary: consistent or not. Architects think in degrees — strong, eventual, causal, read-your-writes.\nEvery system lives somewhere on that spectrum. Knowing where yours sits, and why, is what separates architects from developers.", "angle": 0, "groupIds": []
    },

    {
      "id": "b6-rect",
      "type": "rectangle",
      "x": 40, "y": 666,
      "width": 920, "height": 100,
      "strokeColor": "#3a7a7a", "backgroundColor": "#0a1e1e",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1060, "version": 1, "versionNonce": 1060,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "b6-num",
      "type": "text",
      "x": 62, "y": 678,
      "width": 36, "height": 36,
      "text": "06",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#3a7a7a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1061, "version": 1, "versionNonce": 1061,
      "isDeleted": false, "boundElements": null, "updated": 1,
