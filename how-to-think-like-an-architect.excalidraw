    },
    {
      "id": "b1-title",
      "type": "text",
      "x": 106, "y": 110,
      "width": 830, "height": 22,
      "text": "Stop solving the problem. Start understanding it.",
      "fontSize": 15, "fontFamily": 1,
      "strokeColor": "#89dceb", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1012, "version": 1, "versionNonce": 1012,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Stop solving the problem. Start understanding it.", "angle": 0, "groupIds": []
    },
    {
      "id": "b1-body",
      "type": "text",
      "x": 106, "y": 138,
      "width": 830, "height": 48,
      "text": "A developer asks \"how do I build this?\"  An architect asks \"should we build this at all, and what problem are we actually solving?\"\nThe most expensive systems are the ones that perfectly solve the wrong problem.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1013, "version": 1, "versionNonce": 1013,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "A developer asks \"how do I build this?\"  An architect asks \"should we build this at all, and what problem are we actually solving?\"\nThe most expensive systems are the ones that perfectly solve the wrong problem.", "angle": 0, "groupIds": []
    },

    {
      "id": "b2-rect",
      "type": "rectangle",
      "x": 40, "y": 210,
      "width": 920, "height": 100,
      "strokeColor": "#4a8a5a", "backgroundColor": "#0e2018",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1020, "version": 1, "versionNonce": 1020,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
