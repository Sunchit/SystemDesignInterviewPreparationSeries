    },
    {
      "id": "b6-title",
      "type": "text",
      "x": 698, "y": 422,
      "width": 440, "height": 24,
      "text": "The boring choice is usually the right choice.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#94e2d5", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1062, "version": 1, "versionNonce": 1062,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "The boring choice is usually the right choice.", "angle": 0, "groupIds": []
    },
    {
      "id": "b6-body",
      "type": "text",
      "x": 660, "y": 452,
      "width": 480, "height": 78,
      "text": "Juniors want the newest tech. Architects want tech\ntheir team can operate at 3 AM when it breaks.\nBoring + well-understood beats exciting + unknown.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1063, "version": 1, "versionNonce": 1063,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Juniors want the newest tech. Architects want tech\ntheir team can operate at 3 AM when it breaks.\nBoring + well-understood beats exciting + unknown.", "angle": 0, "groupIds": []
    },

    {
      "id": "b7-rect",
      "type": "rectangle",
      "x": 60, "y": 560,
      "width": 520, "height": 130,
      "strokeColor": "#6a3a7a", "backgroundColor": "#180e20",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1070, "version": 1, "versionNonce": 1070,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "b7-num",
      "type": "text",
      "x": 80, "y": 570,
      "width": 30, "height": 32,
      "text": "07",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#6a3a7a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1071, "version": 1, "versionNonce": 1071,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "07", "angle": 0, "groupIds": []
    },
    {
      "id": "b7-title",
      "type": "text",
      "x": 118, "y": 572,
      "width": 440, "height": 24,
      "text": "Draw the failure boundary before the system.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#f5c2e7", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1072, "version": 1, "versionNonce": 1072,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Draw the failure boundary before the system.", "angle": 0, "groupIds": []
    },
    {
      "id": "b7-body",
      "type": "text",
      "x": 80, "y": 602,
      "width": 480, "height": 78,
      "text": "\"If this fails, what else fails with it?\" — the blast radius\ndetermines your SLA and on-call load.\nServices that fail together should be deployed together.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1073, "version": 1, "versionNonce": 1073,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "\"If this fails, what else fails with it?\" — the blast radius\ndetermines your SLA and on-call load.\nServices that fail together should be deployed together.", "angle": 0, "groupIds": []
    },

    {
      "id": "b8-rect",
      "type": "rectangle",
      "x": 640, "y": 560,
      "width": 520, "height": 130,
      "strokeColor": "#2a7a5a", "backgroundColor": "#0a2018",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1080, "version": 1, "versionNonce": 1080,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "b8-num",
      "type": "text",
      "x": 660, "y": 570,
      "width": 30, "height": 32,
      "text": "08",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#2a7a5a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1081, "version": 1, "versionNonce": 1081,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "08", "angle": 0, "groupIds": []
    },
    {
      "id": "b8-title",
      "type": "text",
      "x": 698, "y": 572,
      "width": 440, "height": 24,
      "text": "Observability is not optional — it is part of the design.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#a6e3a1", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1082, "version": 1, "versionNonce": 1082,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Observability is not optional — it is part of the design.", "angle": 0, "groupIds": []
    },
    {
      "id": "b8-body",
      "type": "text",
      "x": 660, "y": 602,
      "width": 480, "height": 78,
      "text": "A system you cannot observe is one you cannot operate.\nMetrics, traces, and logs are designed in from day one.\nIf you can't answer \"is this healthy?\" in 60s — it's not done.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1083, "version": 1, "versionNonce": 1083,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "A system you cannot observe is one you cannot operate.\nMetrics, traces, and logs are designed in from day one.\nIf you can't answer \"is this healthy?\" in 60s — it's not done.", "angle": 0, "groupIds": []
    },

