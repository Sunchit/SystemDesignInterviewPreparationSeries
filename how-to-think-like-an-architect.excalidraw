    },
    {
      "id": "b9-title",
      "type": "text",
      "x": 106, "y": 1022,
      "width": 830, "height": 22,
      "text": "The best architecture is the one your team can evolve.",
      "fontSize": 15, "fontFamily": 1,
      "strokeColor": "#f9e2af", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1092, "version": 1, "versionNonce": 1092,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "The best architecture is the one your team can evolve.", "angle": 0, "groupIds": []
    },
    {
      "id": "b9-body",
      "type": "text",
      "x": 106, "y": 1050,
      "width": 830, "height": 48,
      "text": "A perfect architecture that no one understands is a liability. Design for the team's current skill level with a clear path to the next level.\nThe goal is not the cleverest solution — it is the most sustainable one. Complexity is a debt that comes with interest.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1093, "version": 1, "versionNonce": 1093,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "A perfect architecture that no one understands is a liability. Design for the team's current skill level with a clear path to the next level.\nThe goal is not the cleverest solution — it is the most sustainable one. Complexity is a debt that comes with interest.", "angle": 0, "groupIds": []
    },

    {
      "id": "b10-rect",
      "type": "rectangle",
      "x": 40, "y": 1122,
      "width": 920, "height": 100,
      "strokeColor": "#8a3a5a", "backgroundColor": "#200a12",
