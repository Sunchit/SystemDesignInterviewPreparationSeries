    },
    {
      "id": "b3-title",
      "type": "text",
      "x": 118, "y": 272,
      "width": 440, "height": 24,
      "text": "Design for failure first, features second.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#f38ba8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1032, "version": 1, "versionNonce": 1032,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Design for failure first, features second.", "angle": 0, "groupIds": []
    },
    {
      "id": "b3-body",
      "type": "text",
      "x": 80, "y": 302,
      "width": 480, "height": 78,
      "text": "Developers design the happy path. Architects design\nfor the crash, timeout, retry, duplicate, and cascade.\nAsk: \"What happens when this fails?\" before building.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1033, "version": 1, "versionNonce": 1033,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Developers design the happy path. Architects design\nfor the crash, timeout, retry, duplicate, and cascade.\nAsk: \"What happens when this fails?\" before building.", "angle": 0, "groupIds": []
    },

    {
      "id": "b4-rect",
      "type": "rectangle",
      "x": 640, "y": 260,
      "width": 520, "height": 130,
      "strokeColor": "#7a5a9a", "backgroundColor": "#18102e",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1040, "version": 1, "versionNonce": 1040,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "b4-num",
      "type": "text",
      "x": 660, "y": 270,
      "width": 30, "height": 32,
      "text": "04",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#7a5a9a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1041, "version": 1, "versionNonce": 1041,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "04", "angle": 0, "groupIds": []
    },
    {
      "id": "b4-title",
      "type": "text",
      "x": 698, "y": 272,
      "width": 440, "height": 24,
      "text": "More is not always better — more is the problem.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#cba6f7", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1042, "version": 1, "versionNonce": 1042,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "More is not always better — more is the problem.", "angle": 0, "groupIds": []
    },
    {
      "id": "b4-body",
      "type": "text",
      "x": 660, "y": 302,
      "width": 480, "height": 78,
      "text": "More connections don't mean more throughput.\nMore services don't mean more scalability.\nQuestion every addition: what does this cost us?",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1043, "version": 1, "versionNonce": 1043,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "More connections don't mean more throughput.\nMore services don't mean more scalability.\nQuestion every addition: what does this cost us?", "angle": 0, "groupIds": []
    },

    {
      "id": "b5-rect",
      "type": "rectangle",
      "x": 60, "y": 410,
      "width": 520, "height": 130,
      "strokeColor": "#8a6a3a", "backgroundColor": "#201808",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1050, "version": 1, "versionNonce": 1050,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "b5-num",
      "type": "text",
      "x": 80, "y": 420,
      "width": 30, "height": 32,
      "text": "05",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#8a6a3a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1051, "version": 1, "versionNonce": 1051,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "05", "angle": 0, "groupIds": []
    },
    {
      "id": "b5-title",
      "type": "text",
      "x": 118, "y": 422,
      "width": 440, "height": 24,
      "text": "Consistency is a spectrum, not a switch.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#f9e2af", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1052, "version": 1, "versionNonce": 1052,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Consistency is a spectrum, not a switch.", "angle": 0, "groupIds": []
    },
    {
      "id": "b5-body",
      "type": "text",
      "x": 80, "y": 452,
      "width": 480, "height": 78,
      "text": "Developers think: consistent or not. Architects think\nin degrees — strong, eventual, causal, read-your-writes.\nKnow where your system sits, and why.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1053, "version": 1, "versionNonce": 1053,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Developers think: consistent or not. Architects think\nin degrees — strong, eventual, causal, read-your-writes.\nKnow where your system sits, and why.", "angle": 0, "groupIds": []
    },

    {
      "id": "b6-rect",
      "type": "rectangle",
      "x": 640, "y": 410,
      "width": 520, "height": 130,
      "strokeColor": "#3a7a7a", "backgroundColor": "#0a1e1e",
