    },
    {
      "id": "b1-title",
      "type": "text",
      "x": 118, "y": 122,
      "width": 440, "height": 24,
      "text": "Stop solving the problem. Start understanding it.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#89dceb", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1012, "version": 1, "versionNonce": 1012,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Stop solving the problem. Start understanding it.", "angle": 0, "groupIds": []
    },
    {
      "id": "b1-body",
      "type": "text",
      "x": 80, "y": 152,
      "width": 480, "height": 78,
      "text": "A developer asks \"how do I build this?\"\nAn architect asks \"should we build this at all?\"\nThe most expensive systems solve the wrong problem perfectly.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1013, "version": 1, "versionNonce": 1013,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "A developer asks \"how do I build this?\"\nAn architect asks \"should we build this at all?\"\nThe most expensive systems solve the wrong problem perfectly.", "angle": 0, "groupIds": []
    },

    {
      "id": "b2-rect",
      "type": "rectangle",
