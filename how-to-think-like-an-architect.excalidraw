      "x": 62, "y": 108,
      "width": 36, "height": 36,
      "text": "01",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#4a7a9a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
