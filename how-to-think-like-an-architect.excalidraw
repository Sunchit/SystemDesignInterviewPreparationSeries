      "originalText": "06", "angle": 0, "groupIds": []
    },
    {
      "id": "b6-title",
      "type": "text",
      "x": 106, "y": 680,
      "width": 830, "height": 22,
      "text": "The boring choice is usually the right choice.",
      "fontSize": 15, "fontFamily": 1,
      "strokeColor": "#94e2d5", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1062, "version": 1, "versionNonce": 1062,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "The boring choice is usually the right choice.", "angle": 0, "groupIds": []
    },
    {
      "id": "b6-body",
      "type": "text",
      "x": 106, "y": 708,
      "width": 830, "height": 48,
      "text": "Junior developers want to use the newest technology. Architects want technology their team can operate at 3 AM when it breaks.\nBoring, well-understood tools with known failure modes beat exciting new ones with unknown edges every time in production.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1063, "version": 1, "versionNonce": 1063,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Junior developers want to use the newest technology. Architects want technology their team can operate at 3 AM when it breaks.\nBoring, well-understood tools with known failure modes beat exciting new ones with unknown edges every time in production.", "angle": 0, "groupIds": []
    },

    {
      "id": "b7-rect",
      "type": "rectangle",
      "x": 40, "y": 780,
      "width": 920, "height": 100,
      "strokeColor": "#6a3a7a", "backgroundColor": "#180e20",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1070, "version": 1, "versionNonce": 1070,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
      "roundness": { "type": 3 }
    },
    {
      "id": "b7-num",
      "type": "text",
      "x": 62, "y": 792,
      "width": 36, "height": 36,
      "text": "07",
      "fontSize": 22, "fontFamily": 1,
      "strokeColor": "#6a3a7a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1071, "version": 1, "versionNonce": 1071,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "07", "angle": 0, "groupIds": []
    },
    {
      "id": "b7-title",
      "type": "text",
      "x": 106, "y": 794,
      "width": 830, "height": 22,
      "text": "Draw the failure boundary before you draw the system.",
      "fontSize": 15, "fontFamily": 1,
      "strokeColor": "#f5c2e7", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1072, "version": 1, "versionNonce": 1072,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Draw the failure boundary before you draw the system.", "angle": 0, "groupIds": []
    },
    {
      "id": "b7-body",
      "type": "text",
      "x": 106, "y": 822,
      "width": 830, "height": 48,
      "text": "Before designing any component, ask: \"If this fails, what else fails with it?\" That blast radius determines your SLA and on-call load.\nServices that fail together should be deployed together. Services that must be isolated must never share a database.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "left", "verticalAlign": "top",
      "seed": 1073, "version": 1, "versionNonce": 1073,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Before designing any component, ask: \"If this fails, what else fails with it?\" That blast radius determines your SLA and on-call load.\nServices that fail together should be deployed together. Services that must be isolated must never share a database.", "angle": 0, "groupIds": []
    },

    {
