    {
      "id": "cache-tx",
      "type": "text",
      "x": 56,
      "y": 442,
      "width": 468,
      "height": 76,
      "text": "CDN CACHING WIN\nQUERY responses are cacheable\nCache key = URL + method + request body\nPOST /search → always hits origin",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
