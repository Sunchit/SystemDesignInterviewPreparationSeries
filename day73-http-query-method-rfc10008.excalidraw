    {
      "id": "flow-tx",
      "type": "text",
      "x": 40,
      "y": 332,
      "width": 1020,
      "height": 72,
      "text": "Read-only? → Yes → Fits in URL? → Yes → GET\n                              → No  → QUERY (RFC 10008)\n              → No  → POST / PUT / PATCH / DELETE",
      "fontSize": 14,
      "fontFamily": 3,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "seed": 73010,
      "version": 1,
      "versionNonce": 73010,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Read-only? → Yes → Fits in URL? → Yes → GET\n                              → No  → QUERY (RFC 10008)\n              → No  → POST / PUT / PATCH / DELETE",
      "angle": 0,
      "groupIds": []
    },
